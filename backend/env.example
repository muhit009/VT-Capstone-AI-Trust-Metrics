# =============================================================================
# GroundCheck Backend — Environment Variable Template
# =============================================================================
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# NEVER commit .env to git. It is listed in .gitignore.
# This file (.env.example) is safe to commit — it contains no real secrets.
#
# Variables marked (required) must be set before the server will start.
# Variables marked (optional) have working defaults for local development.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM Pipeline  (optional — default: ollama)
# -----------------------------------------------------------------------------
# "ollama" → local dev via Ollama HTTP API
# "vllm"   → HPC deployment via vLLM OpenAI-compatible API
PIPELINE=ollama


# -----------------------------------------------------------------------------
# PostgreSQL / Supabase  (required)
# -----------------------------------------------------------------------------
DB_IP=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your-supabase-database-password


# -----------------------------------------------------------------------------
# Ollama  (optional — defaults shown — only used when PIPELINE=ollama)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct


# -----------------------------------------------------------------------------
# vLLM  (optional — defaults shown — only used when PIPELINE=vllm)
# Override at runtime on HPC: VLLM_BASE_URL=http://fal039:8000
# -----------------------------------------------------------------------------
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=mistral-small-24b


# -----------------------------------------------------------------------------
# ChromaDB  (optional — defaults shown)
# -----------------------------------------------------------------------------
CHROMA_PERSIST_PATH=./chroma_db
CHROMA_COLLECTION_NAME=document_embeddings
