# =============================================================================
# GroundCheck Backend — Environment Variable Template
# =============================================================================
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# NEVER commit .env to git. It is listed in .gitignore.
# This file (.env.example) is safe to commit — it contains no real secrets.
#
# Variables marked (required) must be set before the server will start.
# Variables marked (optional) have working defaults for local development.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM Pipeline  (required)
# -----------------------------------------------------------------------------
# "chat"   → NVIDIA NIM or any OpenAI-compatible API (production/Render)
# "ollama" → local dev via Ollama HTTP API
# "vllm"   → HPC deployment via vLLM OpenAI-compatible API
PIPELINE=chat

# Comma-separated allowed frontend origins (omit = allow all in dev only)
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Rate limit on POST /api/v1/query
RATE_LIMIT=10/minute

# -----------------------------------------------------------------------------
# PostgreSQL / Supabase  (required)
# -----------------------------------------------------------------------------
DB_IP=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your-supabase-database-password


# -----------------------------------------------------------------------------
# NVIDIA NIM / Chat API  (required when PIPELINE=chat)
# -----------------------------------------------------------------------------
# Get your API key at: https://build.nvidia.com

CHAT_BASE_URL=https://integrate.api.nvidia.com/v1
CHAT_API_KEY=nvapi-your-nvidia-nim-api-key-here
CHAT_MODEL=mistralai/mistral-medium-3.5-128b


# -----------------------------------------------------------------------------
# Ollama  (optional — defaults shown — only used when PIPELINE=ollama)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b-instruct


# -----------------------------------------------------------------------------
# vLLM  (optional — defaults shown — only used when PIPELINE=vllm)
# Override at runtime on HPC: VLLM_BASE_URL=http://fal039:8000
# -----------------------------------------------------------------------------
VLLM_BASE_URL=http://localhost:8000
VLLM_MODEL=mistral-small-24b


# -----------------------------------------------------------------------------
# ChromaDB  (optional — defaults shown)
# -----------------------------------------------------------------------------
CHROMA_PERSIST_PATH=./chroma_db
CHROMA_COLLECTION_NAME=document_embeddings


# -----------------------------------------------------------------------------
# HuggingFace  (optional — defaults shown)
# HF_TOKEN required for higher rate limits on model downloads
# Set cache paths when deploying to constrained environments (e.g. Render)
# -----------------------------------------------------------------------------
HF_TOKEN=hf_your_token_here
HF_HOME=/tmp/hf_cache
SENTENCE_TRANSFORMERS_HOME=/tmp/sentence_transformers