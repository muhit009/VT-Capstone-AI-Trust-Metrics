{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "installCommand": "echo skip",
  "framework": null,
  "routes": [
    { "src": "/v1/(.*)",     "dest": "/api/proxy?_prefix=/v1&_path=$1" },
    { "src": "/api/v1/(.*)", "dest": "/api/proxy?_prefix=/api/v1&_path=$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)",        "dest": "/index.html" }
  ]
}
