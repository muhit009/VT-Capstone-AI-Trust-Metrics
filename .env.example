# ── GroundCheck Docker environment variables ──────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env — it is in .gitignore.

# ── Supabase PostgreSQL (required) ────────────────────────────────────────
DB_IP=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your-supabase-password-here

# ── LLM pipeline ──────────────────────────────────────────────────────────
# "ollama" → uses the ollama container (default, works out of the box)
# "vllm"   → uses an external vLLM endpoint (HPC / TinkerCliffs)
PIPELINE=ollama

# Ollama service URL.
# Default points to the ollama container on the Docker network.
# To use Ollama running on your HOST machine instead of the container:
#   OLLAMA_BASE_URL=http://host.docker.internal:11434   (Docker Desktop / Mac / Windows)
#   OLLAMA_BASE_URL=http://172.17.0.1:11434             (Linux — check docker0 bridge IP)
OLLAMA_BASE_URL=http://ollama:11434

# ── Frontend ──────────────────────────────────────────────────────────────
VITE_APP_NAME=AI Trust Metrics
